{
  "commands": [
  {"cmd":"read","desc":"Read input from user","category":"shell","explanation":"Reads a line from standard input and assigns it to a variable.","usage":"read variable","examples":["read name","echo $name"]},
  {"cmd":"test","desc":"Evaluate conditional expressions","category":"shell","explanation":"Tests conditions such as file types, string comparisons, and numeric comparisons; returns true (0) or false (1) for use in control flow.","usage":"test EXPRESSION","examples":["test -f file.txt","test 5 -gt 3","test \"$name\" = \"Alice\""]},
  {"cmd":"type","desc":"Show command type","category":"shell","explanation":"Shows if a command is built-in, alias, function, or external program.","usage":"type command","examples":["type ls","type cd"]},
  {"cmd":"seq","desc":"Generate sequences of numbers","category":"shell","explanation":"Prints numbers from start to end optionally with a step.","usage":"seq start end","examples":["seq 1 10","seq 0 2 10"]},
  {"cmd":"yes","desc":"Print string repeatedly","category":"shell","explanation":"Outputs a string (default 'y') until killed.","usage":"yes [string]","examples":["yes","yes no"]},
  {"cmd":"sleep","desc":"Pause for seconds","category":"shell","explanation":"Waits for a specified amount of time.","usage":"sleep seconds","examples":["sleep 5","sleep 0.5"]},
  {"cmd":"uname","desc":"Show system info","category":"system","explanation":"Prints kernel name, version, and other info.","usage":"uname [options]","examples":["uname -a","uname -r"]},
  {"cmd":"hostname","desc":"Show or set system hostname","category":"system","explanation":"Displays or sets the hostname of the system.","usage":"hostname [name]","examples":["hostname","hostname newname"]},
  {"cmd":"whoami","desc":"Show current user","category":"system","explanation":"Prints effective username of the current user.","usage":"whoami","examples":["whoami"]},
  {"cmd":"id","desc":"Show user identity","category":"system","explanation":"Prints user and group IDs.","usage":"id [username]","examples":["id","id root"]},
  {"cmd":"groups","desc":"Show user groups","category":"system","explanation":"Lists the groups a user belongs to.","usage":"groups [username]","examples":["groups","groups john"]},
  {"cmd":"df","desc":"Disk usage","category":"filesystem","explanation":"Shows available and used disk space.","usage":"df [options] [filesystem]","examples":["df -h","df -i"]},
  {"cmd":"du","desc":"Directory size","category":"filesystem","explanation":"Shows disk usage of files and directories.","usage":"du [options] [file/directory]","examples":["du -sh *","du -ah /var/log"]},
  {"cmd":"mount","desc":"Mount filesystem","category":"filesystem","explanation":"Mounts a filesystem at a directory.","usage":"mount device mountpoint","examples":["mount /dev/sda1 /mnt"]},
  {"cmd":"umount","desc":"Unmount filesystem","category":"filesystem","explanation":"Unmounts a mounted filesystem.","usage":"umount mountpoint","examples":["umount /mnt"]},
  {"cmd":"ls","desc":"List files and directories","category":"filesystem","explanation":"Displays files and directories in the current location.","usage":"ls [options] [directory]","examples":["ls","ls -la","ls /home/user"]},
  {"cmd":"cd","desc":"Change directory","category":"filesystem","explanation":"Moves you into another directory.","usage":"cd [directory]","examples":["cd /home","cd ..","cd ~"]},
  {"cmd":"pwd","desc":"Print current working directory","category":"filesystem","explanation":"Shows the full path of your current directory.","usage":"pwd","examples":["pwd"]},
  {"cmd":"mkdir","desc":"Create directory","category":"filesystem","explanation":"Creates a new directory.","usage":"mkdir [options] directory","examples":["mkdir test","mkdir -p a/b/c"]},
  {"cmd":"rmdir","desc":"Remove empty directory","category":"filesystem","explanation":"Deletes empty directories.","usage":"rmdir [directory]","examples":["rmdir test"]},
  {"cmd":"touch","desc":"Create empty file","category":"filesystem","explanation":"Creates a new empty file or updates timestamps.","usage":"touch [file]","examples":["touch file.txt"]},
  {"cmd":"cp","desc":"Copy files or directories","category":"filesystem","explanation":"Copies files or directories to another location.","usage":"cp [options] source destination","examples":["cp file.txt backup.txt","cp -r dir1 dir2"]},
  {"cmd":"mv","desc":"Move or rename files","category":"filesystem","explanation":"Moves or renames files and directories.","usage":"mv [source] [destination]","examples":["mv file.txt new.txt"]},
  {"cmd":"rm","desc":"Remove files","category":"filesystem","explanation":"Deletes files or directories.","usage":"rm [options] [file]","examples":["rm file.txt","rm -r folder"]},
  {"cmd":"file","desc":"Determine file type","category":"filesystem","explanation":"Prints the type of a file.","usage":"file filename","examples":["file script.sh","file image.png"]},
  {"cmd":"cat","desc":"View file contents","category":"files","explanation":"Prints file contents to terminal.","usage":"cat [file]","examples":["cat file.txt"]},
  {"cmd":"less","desc":"View file interactively","category":"files","explanation":"Allows scrolling through file content.","usage":"less [file]","examples":["less file.txt"]},
  {"cmd":"head","desc":"Show first lines of file","category":"files","explanation":"Displays the beginning of a file.","usage":"head [options] file","examples":["head file.txt","head -n 20 file.txt"]},
  {"cmd":"tail","desc":"Show last lines of file","category":"files","explanation":"Displays the end of a file.","usage":"tail [options] file","examples":["tail file.txt","tail -f log.txt"]},
  {"cmd":"wc","desc":"Count lines/words/characters","category":"files","explanation":"Counts lines, words, and characters in a file.","usage":"wc [options] file","examples":["wc file.txt","wc -l file.txt"]},
  {"cmd":"grep","desc":"Search text in files","category":"search","explanation":"Searches for patterns in files.","usage":"grep [options] pattern file","examples":["grep 'error' log.txt","grep -r hello ."]},
  {"cmd":"find","desc":"Find files","category":"search","explanation":"Searches for files in directories.","usage":"find [path] [conditions]","examples":["find . -name '*.txt'","find /var -type f -size +1M"]},
  {"cmd":"locate","desc":"Quick file search","category":"search","explanation":"Finds files quickly using a database.","usage":"locate filename","examples":["locate file.txt"]},
  {"cmd":"chmod","desc":"Change permissions","category":"permissions","explanation":"Modifies file access permissions.","usage":"chmod [options] mode file","examples":["chmod 755 script.sh","chmod u+x file.sh"]},
  {"cmd":"chown","desc":"Change ownership","category":"permissions","explanation":"Changes file owner/group.","usage":"chown user:group file","examples":["chown user file.txt","chown user:group file.txt"]},
  {"cmd":"chgrp","desc":"Change group ownership","category":"permissions","explanation":"Changes the group ownership of a file.","usage":"chgrp group file","examples":["chgrp staff file.txt"]},
  {"cmd":"ps","desc":"Show processes","category":"system","explanation":"Displays running processes.","usage":"ps [options]","examples":["ps","ps aux"]},
  {"cmd":"top","desc":"Monitor processes","category":"system","explanation":"Real-time process viewer.","usage":"top","examples":["top"]},
  {"cmd":"kill","desc":"Terminate process","category":"system","explanation":"Stops a process by PID.","usage":"kill [PID]","examples":["kill 1234"]},
  {"cmd":"free","desc":"Memory usage","category":"system","explanation":"Displays RAM and swap usage.","usage":"free [options]","examples":["free -h"]},
  {"cmd":"dmesg","desc":"Kernel messages","category":"system","explanation":"Displays kernel ring buffer messages.","usage":"dmesg [options]","examples":["dmesg","dmesg | tail"]},
  {"cmd":"lsof","desc":"List open files","category":"system","explanation":"Displays files currently opened by processes.","usage":"lsof [options]","examples":["lsof -i","lsof /var/log/syslog"]},
  {"cmd":"alias","desc":"Create shortcut for commands","category":"shell","explanation":"Creates command shortcuts.","usage":"alias name='command'","examples":["alias ll='ls -la'"]},
  {"cmd":"unalias","desc":"Remove alias","category":"shell","explanation":"Deletes an alias previously created.","usage":"unalias name","examples":["unalias ll"]},
  {"cmd":"history","desc":"Command history","category":"shell","explanation":"Displays previously run commands.","usage":"history [options]","examples":["history","history | grep ls"]},
  {"cmd":"ping","desc":"Test connectivity","category":"network","explanation":"Checks network connectivity to a host.","usage":"ping host","examples":["ping google.com","ping -c 4 example.com"]},
  {"cmd":"ss","desc":"Socket statistics","category":"network","explanation":"Displays detailed socket statistics.","usage":"ss [options]","examples":["ss -tuln","ss -s"]},
  {"cmd":"traceroute","desc":"Trace route packets take","category":"network","explanation":"Shows path packets take to a host.","usage":"traceroute host","examples":["traceroute google.com"]},
  {"cmd":"basename","desc":"Extract filename from path","category":"filesystem","explanation":"Prints the final component of a path.","usage":"basename path","examples":["basename /home/user/file.txt"]},
  {"cmd":"dirname","desc":"Extract directory path","category":"filesystem","explanation":"Prints the directory portion of a path.","usage":"dirname path","examples":["dirname /home/user/file.txt"]},
  {"cmd":"diff","desc":"Compare files line by line","category":"files","explanation":"Shows differences between two files.","usage":"diff file1 file2","examples":["diff old.txt new.txt"]},
  {"cmd":"comm","desc":"Compare sorted files","category":"files","explanation":"Shows common and unique lines between two sorted files.","usage":"comm file1 file2","examples":["comm sorted1.txt sorted2.txt"]},
  {"cmd":"tee","desc":"Read from stdin and write to stdout and file","category":"shell","explanation":"Splits input to display and save simultaneously.","usage":"command | tee file","examples":["echo hello | tee out.txt"]},
  {"cmd":"env","desc":"Show environment variables","category":"shell","explanation":"Displays environment or runs a command in a modified environment.","usage":"env [command]","examples":["env","env VAR=value command"]},
  {"cmd":"export","desc":"Set environment variable","category":"shell","explanation":"Sets environment variables for child processes.","usage":"export VAR=value","examples":["export PATH=$PATH:/new/path"]},
  {"cmd":"jobs","desc":"List background jobs","category":"shell","explanation":"Shows jobs started in the current shell.","usage":"jobs","examples":["jobs"]},
  {"cmd":"fg","desc":"Bring background job to foreground","category":"shell","explanation":"Moves a background job into the foreground.","usage":"fg [%job]","examples":["fg %1"]},
  {"cmd":"bg","desc":"Resume job in background","category":"shell","explanation":"Resumes a suspended job in the background.","usage":"bg [%job]","examples":["bg %1"]},
  {"cmd":"wait","desc":"Wait for background processes","category":"shell","explanation":"Waits for all background processes or a specific PID to finish.","usage":"wait [pid]","examples":["wait","wait 1234"]},
  {"cmd":"expr","desc":"Evaluate arithmetic or string expressions","category":"shell","explanation":"Performs arithmetic and string operations.","usage":"expr expression","examples":["expr 5 + 3","expr length string"]},
  {"cmd":"paste","desc":"Merge lines of files","category":"files","explanation":"Combines lines from multiple files horizontally.","usage":"paste file1 file2","examples":["paste file1.txt file2.txt"]},
  {"cmd":"tr","desc":"Translate or delete characters","category":"files","explanation":"Transforms or removes characters in input.","usage":"tr SET1 SET2","examples":["echo abc | tr a-z A-Z","tr -d '\n' < file.txt"]},
  {"cmd":"split","desc":"Split file into pieces","category":"files","explanation":"Splits large files into smaller files of fixed size or lines.","usage":"split [options] file","examples":["split -l 1000 bigfile.txt part_"]},
  {"cmd":"cmp","desc":"Compare two files byte by byte","category":"files","explanation":"Shows first difference between two files.","usage":"cmp file1 file2","examples":["cmp file1 file2"]},
  {"cmd":"sha256sum","desc":"Compute SHA256 hash","category":"files","explanation":"Prints SHA256 hash of file contents.","usage":"sha256sum file","examples":["sha256sum file.txt"]},
  {"cmd":"md5sum","desc":"Compute MD5 hash","category":"files","explanation":"Prints MD5 hash of file contents.","usage":"md5sum file","examples":["md5sum file.txt"]},
  {"cmd":"gzip","desc":"Compress file using gzip","category":"compression","explanation":"Compresses or decompresses files in gzip format.","usage":"gzip file","examples":["gzip file.txt","gzip -d file.txt.gz"]},
  {"cmd":"bzip2","desc":"Compress file using bzip2","category":"compression","explanation":"Compresses or decompresses files in bzip2 format.","usage":"bzip2 file","examples":["bzip2 file.txt","bzip2 -d file.txt.bz2"]},
  {"cmd":"xz","desc":"Compress file using xz","category":"compression","explanation":"Compresses or decompresses files in xz format.","usage":"xz file","examples":["xz file.txt","xz -d file.txt.xz"]},
  {"cmd":"tar","desc":"Archive files","category":"compression","explanation":"Creates or extracts tar archives.","usage":"tar [options] archive files","examples":["tar -cvf file.tar folder","tar -xvf file.tar"]},
  {"cmd":"zip","desc":"Create zip archive","category":"compression","explanation":"Compresses files into zip format.","usage":"zip archive files","examples":["zip archive.zip file.txt"]},
  {"cmd":"unzip","desc":"Extract zip archive","category":"compression","explanation":"Extracts files from a zip archive.","usage":"unzip file.zip","examples":["unzip archive.zip"]},
  {"cmd":"nice","desc":"Run process with adjusted priority","category":"system","explanation":"Starts a process with a modified scheduling priority.","usage":"nice -n N command","examples":["nice -n 10 top"]},
  {"cmd":"renice","desc":"Change priority of running process","category":"system","explanation":"Adjusts the scheduling priority of running processes.","usage":"renice -n N -p PID","examples":["renice -n 5 -p 1234"]},
  {"cmd":"pgrep","desc":"Find process by name","category":"system","explanation":"Searches for processes matching a pattern.","usage":"pgrep pattern","examples":["pgrep sshd"]},
  {"cmd":"pkill","desc":"Kill process by name","category":"system","explanation":"Terminates processes matching a pattern.","usage":"pkill pattern","examples":["pkill firefox"]},
  {"cmd":"watch","desc":"Run command periodically","category":"system","explanation":"Executes a command repeatedly, displaying output.","usage":"watch command","examples":["watch -n 2 df -h"]},
  {"cmd":"uptime","desc":"Show system uptime","category":"system","explanation":"Displays system uptime and load averages.","usage":"uptime","examples":["uptime"]},
  {"cmd":"stat","desc":"Show file status","category":"filesystem","explanation":"Displays detailed info about a file or directory.","usage":"stat file","examples":["stat file.txt"]},
  {"cmd":"umask","desc":"Default permission mask","category":"permissions","explanation":"Shows or sets default file creation permissions.","usage":"umask [mask]","examples":["umask","umask 022"]},
  {"cmd":"who","desc":"Show logged in users","category":"system","explanation":"Displays users currently logged into the system.","usage":"who","examples":["who"]},
  {"cmd":"w","desc":"Show logged in users and activity","category":"system","explanation":"Shows who is logged in and what they are doing.","usage":"w","examples":["w"]},
  {"cmd":"last","desc":"Show login history","category":"system","explanation":"Displays last logged-in users.","usage":"last [user]","examples":["last","last root"]},
  {"cmd":"printf","desc":"Formatted output","category":"shell","explanation":"Prints formatted text to stdout.","usage":"printf format [arguments]","examples":["printf 'Hello %s\n' World"]}
  ]
}
